{
  "test_name": "python_spiky",
  "stacks": [
    {
      "profile-type": "wall-time",
      "stack-content": [
        {
          "regular_expression": ".*cpu_spike",
          "percent": 50,
          "error_margin": 10
        },
        {
          "regular_expression": ".*sleep_period",
          "percent": 50,
          "error_margin": 10
        }
      ]
    },
    {
      "profile-type": "cpu-time",
      "stack-content": [
        {
          "regular_expression": ".*cpu_spike",
          "percent": 99,
          "error_margin": 5
        },
        {
          "regular_expression": ".*sleep_period",
          "percent": 0,
          "error_margin": 5
        }
      ]
    }
  ],
  "scale_by_duration": false
}
