{
  "test_name": "python_mem_domain_3.14",
  "pprof-regex": "profiles\\.([2-9]|[1-9][0-9]+)\\..*\\.pprof$",
  "allow_first_profile_failure": true,
  "stacks": [
    {
      "profile-type": "heap-space",
      "stack-content": [
        {
          "regular_expression": ".*allocate_mem_domain_buffer.*",
          "percent": 50,
          "error_margin": 50
        }
      ]
    }
  ],
  "scale_by_duration": false
}
